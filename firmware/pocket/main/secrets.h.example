// Copy to firmware/pocket/main/secrets.h and fill in.
// secrets.h is gitignored — never commit real credentials.
#pragma once

// Wi-Fi the ESP32 should join.
#define POCKET_WIFI_SSID     "your-ssid"
#define POCKET_WIFI_PASSWORD "your-password"

// WebSocket URL of the bridge running on your Mac. Include port 8789.
// The bridge listens on 0.0.0.0:8789 by default; use the Mac's LAN IP here.
// Example: "ws://192.168.1.42:8789"
#define POCKET_BRIDGE_URL    "ws://REPLACE_ME:8789"
